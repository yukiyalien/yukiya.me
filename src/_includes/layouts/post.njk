<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} - ももつきゆきや</title>
  <meta name="description" content="{{ description or 'ももつきゆきやのブログ記事' }}">

  <meta name="color-scheme" content="light dark">
  <meta name="theme-color" content="#FEF6DF">
  <meta name="theme-color" media="(prefers-color-scheme: light)" content="#FEF6DF">
  <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#1F1A17">

  <meta property="og:type" content="article">
  <meta property="og:site_name" content="ももつきゆきや">
  <meta property="og:title" content="{{ title }} - ももつきゆきや">
  <meta property="og:description" content="{{ description or 'ももつきゆきやのブログ記事' }}">
  <meta property="og:url" content="https://yukiya.me{{ page.url }}">
  <meta property="og:image" content="https://yukiya.me/icon.jpg">

  <meta name="twitter:card" content="summary_large_image">
  <meta name="fediverse:creator" content="@yukiyalien@cho.yukiya.me">

  <link rel="icon" href="/favicon.ico">
  <link rel="stylesheet" href="/style.css">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=M+PLUS+Rounded+1c:wght@100;300;400;500;700;800;900&display=swap" rel="stylesheet">
</head>
<body>
  {% include "site-header.njk" %}
  <div class="page page-post">
    <main>
      <article class="contents bio">
        <header class="post-header">
          <div class="post-header-main">
            <div class="post-header-icon">
              <img src="/icon.jpg" alt="Yukiya Momotsuki" class="post-icon-img">
            </div>
            <div class="post-header-text">
              <nav class="post-breadcrumb" aria-label="パンくずリスト">
                <a href="/">yukiya.me</a>
                <span aria-hidden="true">›</span>
                <a href="/blog/">blog</a>
                <span aria-hidden="true">›</span>
                <span aria-current="page">{{ page.fileSlug }}</span>
              </nav>
              <h1 class="post-title">{{ title }}</h1>
              {% if date %}
              <p class="post-meta">
                <time datetime="{{ date | jpDate }}">{{ date | jpDate }}</time>
              </p>
              {% endif %}
            </div>
          </div>
        </header>

        {% set fullUrl = 'https://yukiya.me' + page.url %}
        {% set shareText = title + ' ' + fullUrl %}
        {% include "post-share.njk" %}

        <section class="post-body">
          {{ content | safe }}
        </section>

        {% include "post-share.njk" %}
        <script>
          (function () {
            var sections = document.querySelectorAll('.post-share');
            sections.forEach(function (section) {
              var title = section.dataset.shareTitle || '';
              var url = section.dataset.shareUrl || '';
              var nativeBtn = section.querySelector('.post-share-native');
              var copyBtn = section.querySelector('.post-share-copy');
              if (nativeBtn) {
                if (typeof navigator !== 'undefined' && navigator.share) {
                  nativeBtn.addEventListener('click', function () {
                    navigator.share({ title: title, text: title, url: url }).catch(function () {});
                  });
                } else {
                  nativeBtn.style.display = 'none';
                }
              }
              if (copyBtn) {
                var copyIcon = copyBtn.querySelector('.post-share-icon-copy');
                var doneIcon = copyBtn.querySelector('.post-share-icon-done');
                var defaultLabel = copyBtn.getAttribute('aria-label');
                copyBtn.addEventListener('click', function () {
                  var text = title + '\n' + url;
                  if (navigator.clipboard && navigator.clipboard.writeText) {
                    navigator.clipboard.writeText(text).then(function () {
                      copyBtn.setAttribute('aria-label', 'コピーしました');
                      if (copyIcon) copyIcon.hidden = true;
                      if (doneIcon) doneIcon.hidden = false;
                      setTimeout(function () {
                        copyBtn.setAttribute('aria-label', defaultLabel || '');
                        if (copyIcon) copyIcon.hidden = false;
                        if (doneIcon) doneIcon.hidden = true;
                      }, 2000);
                    }).catch(function () {});
                  }
                });
              }
            });
          })();
        </script>
      </article>
    </main>

    <footer>
      <p>&copy; 2019-{{ currentYear }} Yukiya Momotsuki</p>
    </footer>
  </div>
</body>
</html>

