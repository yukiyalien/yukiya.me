  <script>
    (() => {
      const copyButtons = document.querySelectorAll("[data-copy-text]");

      const copyText = async (text) => {
        if (navigator.clipboard && navigator.clipboard.writeText) {
          await navigator.clipboard.writeText(text);
          return;
        }

        const textarea = document.createElement("textarea");
        textarea.value = text;
        textarea.setAttribute("readonly", "");
        textarea.style.position = "absolute";
        textarea.style.left = "-9999px";
        document.body.appendChild(textarea);
        textarea.select();
        document.execCommand("copy");
        document.body.removeChild(textarea);
      };

      copyButtons.forEach((button) => {
        button.addEventListener("click", async () => {
          const subLabel = button.querySelector(".link-sub");
          const originalLabel = subLabel ? subLabel.textContent : button.textContent;
          try {
            await copyText(button.dataset.copyText || "");
            if (subLabel) {
              subLabel.textContent = "コピーしました！";
            } else {
              button.textContent = "コピーしました！";
            }
          } catch (error) {
            if (subLabel) {
              subLabel.textContent = "コピー失敗";
            } else {
              button.textContent = "コピー失敗";
            }
          }

          window.setTimeout(() => {
            if (subLabel) {
              subLabel.textContent = originalLabel;
            } else {
              button.textContent = originalLabel;
            }
          }, 1200);
        });
      });
    })();
  </script>
